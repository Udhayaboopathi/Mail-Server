# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/emaildb
POSTGRES_DB=emaildb
POSTGRES_USER=emailuser
POSTGRES_PASSWORD=change-this-strong-password

# ── Cache / Broker ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-256-bit-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Encryption (for Cloudflare tokens, PGP keys) ─────────────
ENCRYPTION_SECRET_KEY=replace-with-32-byte-base64-secret

# ── Mail server ───────────────────────────────────────────────
SMTP_HOSTNAME=mail.yourdomain.com
MAILDIR_BASE=/var/mail
MAX_MESSAGE_SIZE_MB=25
DKIM_SELECTOR=mail
SERVER_IP=your-vps-public-ip

# ── Cloudflare (global fallback, per-domain stored in DB) ─────
CLOUDFLARE_API_TOKEN=optional-global-fallback-token

# ── Backup ────────────────────────────────────────────────────
BACKUP_PASSPHRASE=optional-encrypt-backups
BACKUP_RETENTION_DAYS=7

# ── Invites / password reset ──────────────────────────────────
INVITE_BASE_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Super admin seed ──────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=change-immediately

# ── AI features (Claude API) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
AI_SUMMARY_ENABLED=true
AI_SMART_REPLY_ENABLED=true
AI_PRIORITY_INBOX_ENABLED=true

# ── Tracking ──────────────────────────────────────────────────
TRACKING_BASE_URL=https://yourdomain.com/track
TRACKING_ENABLED=true

# ── SpamAssassin / ClamAV ─────────────────────────────────────
SPAMASSASSIN_HOST=spamassassin
CLAMAV_HOST=clamav

# ── IP Geolocation (free, no key needed) ──────────────────────
IP_GEO_URL=http://ip-api.com/json
