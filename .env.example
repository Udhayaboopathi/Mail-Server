DATABASE_URL=postgresql+asyncpg://emailuser:change-this@postgres:5432/emaildb
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
MAIL_DOMAIN=mail.yourdomain.com
MAILDIR_BASE=/var/mail
MAX_MESSAGE_SIZE_MB=25
DKIM_SELECTOR=mail
DKIM_PRIVATE_KEY_PATH=/etc/dkim/private.key
SPAMASSASSIN_HOST=spamassassin
CLAMAV_HOST=clamav
SMTP_HOSTNAME=mail.yourdomain.com
ENABLE_MAIL_SERVERS=true
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
SERVER_IP=
POSTGRES_DB=emaildb
POSTGRES_USER=emailuser
POSTGRES_PASSWORD=change-this
NEXT_PUBLIC_API_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
